{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {

    "deleteOutDir": true,
    "assets": [
      { "include": "**/migrations/*.ts", "outDir": "dist" },
      { "include": "**/migrations/*.js", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}
